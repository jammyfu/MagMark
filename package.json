{
  "name": "magmark",
  "version": "1.6.0",
  "description": "World-class magazine-quality markdown converter",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "percy snapshot .",
    "gen:tokens": "node scripts/gen-typescript-from-tokens.mjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "keywords": [
    "markdown",
    "magazine",
    "typography",
    "pdf",
    "converter",
    "typesetting",
    "publishing",
    "xiaohongshu",
    "wechat"
  ],
  "author": "MagMark Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/magmark/magmark-2.0.git"
  },
  "bugs": {
    "url": "https://github.com/magmark/magmark-2.0/issues"
  },
  "homepage": "https://github.com/magmark/magmark-2.0#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@tiptap/core": "^2.1.0",
    "@tiptap/extension-image": "^2.1.0",
    "@tiptap/extension-link": "^2.1.0",
    "@tiptap/extension-placeholder": "^2.1.0",
    "@tiptap/extension-typography": "^2.1.0",
    "@tiptap/react": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "archiver": "^6.0.0",
    "canvas": "^3.2.1",
    "html-to-image": "^1.11.13",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.32.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-stringify": "^10.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@percy/cli": "^1.27.0",
    "@playwright/test": "^1.40.0",
    "@types/archiver": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.0",
    "terser": "^5.46.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "playwright-core": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright-core": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "4.59.0",
    "@rollup/wasm-node": "4.59.0"
  }
}