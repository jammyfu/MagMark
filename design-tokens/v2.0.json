{
  "version": "2.0",
  "lastUpdated": "2026-03-03",
  "grid": {
    "columns": 12,
    "baselineStep": 8,
    "baselineUnit": "px",
    "gutter": 24
  },
  "margins": {
    "mobile": "8%",
    "desktop": "10%",
    "print": "48px"
  },
  "typography": {
    "lineHeight": 1.75,
    "lineHeightRange": [1.6, 1.8],
    "paragraphSpacing": 1.5,
    "maxCharsPerLine": 40,
    "minCharsPerLine": 15,
    "widowsOrphans": 2,
    "autoSpaceCjk": true,
    "hangPunctuationPx": 2
  },
  "whiteSpace": {
    "paddingPercentage": "70-75%",
    "ratioGolden": 0.618,
    "ratio3to4": 0.75,
    "ratio16to9": 0.5625
  },
  "platforms": {
    "xiaohongshu": {
      "primary": {"width": 1080, "height": 1440, "ratio": "3:4"},
      "alternative": {"width": 1242, "height": 1660}
    },
    "wechat": {"width": 1080, "aspectRatio": "long"},
    "cover": {"width": 1080, "height": 383},
    "pdf": ["A4", "Letter"],
    "web": "responsive"
  },
  "pagination": {
    "manualMarkers": ["---", "<!-- page-break -->"],
    "avoidBreakInside": true,
    "chapterNewPage": true,
    "dragPointSupport": true
  },
  "images": {
    "fullBleed": true,
    "captionAlign": "left",
    "separatorColor": "#e0e0e0",
    "preferredRatios": ["golden", "3:4", "16:9"]
  },
  "typographySystem": {
    "primaryFont": "Source Han Serif SC / Noto Serif SC",
    "fallbackFonts": ["SimSun", "STSong", "Times New Roman"],
    "levels": [
      {"tag": "h1", "fontSize": 32, "fontWeight": 700, "lineHeight": 1.2},
      {"tag": "h2", "fontSize": 24, "fontWeight": 600, "lineHeight": 1.3},
      {"tag": "h3", "fontSize": 18, "fontWeight": 600, "lineHeight": 1.4},
      {"tag": "h4", "fontSize": 16, "fontWeight": 600, "lineHeight": 1.5},
      {"tag": "p", "fontSize": 14, "fontWeight": 400, "lineHeight": 1.75},
      {"tag": "small", "fontSize": 12, "fontWeight": 400, "lineHeight": 1.5}
    ]
  },
  "colors": {
    "textPrimary": "#1a1a1a",
    "textSecondary": "#666666",
    "background": "#ffffff",
    "accent": "#d32f2f",
    "border": "#e0e0e0"
  }
}
